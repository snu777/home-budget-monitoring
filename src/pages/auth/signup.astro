---
import Layout from "@/layouts/Layout.astro";
import SignUpForm from "@/components/auth/SignUpForm";
import AuthBrand from "@/components/auth/AuthBrand.astro";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Załóż konto">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <AuthBrand subtitle="Załóż konto i zacznij śledzić wspólne wydatki." />
      <div
        class="rounded-2xl border border-slate-800 bg-slate-900/70 p-8 text-slate-100 shadow-xl shadow-black/30 backdrop-blur-xl"
      >
        <h1 class="mb-6 text-center text-xl font-semibold text-white">Rejestracja</h1>
        <SignUpForm serverError={error} client:load />
        <p class="mt-6 text-center text-sm text-slate-400">
          Masz już konto?{" "}
          <a href="/auth/signin" class="font-medium text-emerald-400 transition-colors hover:text-emerald-300">
            Zaloguj się
          </a>
        </p>
      </div>
    </div>
  </div>
</Layout>
