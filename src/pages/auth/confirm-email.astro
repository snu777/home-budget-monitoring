---
import Layout from "@/layouts/Layout.astro";
import AuthBrand from "@/components/auth/AuthBrand.astro";

const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      heading: "Rejestracja zakończona",
      description: "Twoje konto zostało utworzone. Możesz się teraz zalogować.",
      linkText: "Przejdź do logowania",
    }
  : {
      heading: "Sprawdź skrzynkę",
      description: "Wysłaliśmy link aktywacyjny na Twój adres email. Kliknij go, aby aktywować konto.",
      linkText: "Wróć do logowania",
    };
---

<Layout title={content.heading}>
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <AuthBrand />
      <div
        class="rounded-2xl border border-slate-800 bg-slate-900/70 p-8 text-center text-slate-100 shadow-xl shadow-black/30 backdrop-blur-xl"
      >
        <span
          class="mx-auto mb-5 flex size-12 items-center justify-center rounded-full bg-emerald-500/15 text-emerald-400"
        >
          {
            isAutoConfirmed ? (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="size-6"
                aria-hidden="true"
              >
                <path d="M21.801 10A10 10 0 1 1 17 3.335" />
                <path d="m9 11 3 3L22 4" />
              </svg>
            ) : (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="size-6"
                aria-hidden="true"
              >
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            )
          }
        </span>
        <h1 class="mb-3 text-xl font-semibold text-white">{content.heading}</h1>
        <p class="mb-6 text-sm text-slate-400">{content.description}</p>
        <a href="/auth/signin" class="text-sm font-medium text-emerald-400 transition-colors hover:text-emerald-300">
          {content.linkText}
        </a>
      </div>
    </div>
  </div>
</Layout>
