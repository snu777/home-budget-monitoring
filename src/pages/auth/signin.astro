---
import Layout from "@/layouts/Layout.astro";
import SignInForm from "@/components/auth/SignInForm";
import AuthBrand from "@/components/auth/AuthBrand.astro";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Zaloguj się">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm">
      <AuthBrand subtitle="Zaloguj się, aby zobaczyć wspólny budżet." />
      <div
        class="rounded-2xl border border-slate-800 bg-slate-900/70 p-8 text-slate-100 shadow-xl shadow-black/30 backdrop-blur-xl"
      >
        <h1 class="mb-6 text-center text-xl font-semibold text-white">Logowanie</h1>
        <SignInForm serverError={error} client:load />
        <p class="mt-6 text-center text-sm text-slate-400">
          Nie masz konta?{" "}
          <a href="/auth/signup" class="font-medium text-emerald-400 transition-colors hover:text-emerald-300">
            Załóż konto
          </a>
        </p>
      </div>
    </div>
  </div>
</Layout>
