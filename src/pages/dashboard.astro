---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import ExpenseDashboard from "@/components/expenses/ExpenseDashboard";

const { user } = Astro.locals;
if (!user) return Astro.redirect("/auth/signin");
const supabase = createClient(Astro.request.headers, Astro.cookies);

const errorMessage = Astro.url.searchParams.get("error");

let budget: { id: string; name: string | null; invite_code: string } | null = null;

if (supabase) {
  const { data: membership } = await supabase
    .from("budget_members")
    .select("budget_id")
    .eq("user_id", user.id)
    .maybeSingle();

  if (membership) {
    const { data } = await supabase
      .from("budgets")
      .select("id, name, invite_code")
      .eq("id", membership.budget_id)
      .single();
    budget = data;
  }
}
---

<Layout title="Dashboard">
  <div class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto max-w-2xl">
      <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
          Home Budget
        </h1>
        <div class="flex items-center gap-3">
          <span class="text-sm text-blue-100/60">{user.email}</span>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="rounded-lg border border-white/20 bg-white/10 px-3 py-1.5 text-sm transition-colors hover:bg-white/20"
            >
              Wyloguj
            </button>
          </form>
        </div>
      </div>

      {
        errorMessage && (
          <div class="mb-4 rounded-lg border border-red-500/30 bg-red-500/10 p-3 text-sm text-red-300">
            {errorMessage}
          </div>
        )
      }

      {
        !budget ? (
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
              <h2 class="mb-4 text-lg font-semibold">Utwórz nowy budżet</h2>
              <form method="POST" action="/api/budgets" class="space-y-4">
                <div>
                  <label for="budget-name" class="mb-1 block text-sm text-blue-100/70">
                    Nazwa budżetu
                  </label>
                  <input
                    id="budget-name"
                    type="text"
                    name="name"
                    value="Nasz budżet"
                    class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:ring-1 focus:ring-white/30 focus:outline-none"
                  />
                </div>
                <button
                  type="submit"
                  class="w-full rounded-lg bg-purple-600 px-4 py-2 font-semibold transition-colors hover:bg-purple-700"
                >
                  Utwórz budżet
                </button>
              </form>
            </div>

            <div class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
              <h2 class="mb-4 text-lg font-semibold">Dołącz do budżetu</h2>
              <form method="POST" action="/api/budgets/join" class="space-y-4">
                <div>
                  <label for="invite-code-input" class="mb-1 block text-sm text-blue-100/70">
                    Kod zaproszenia
                  </label>
                  <input
                    id="invite-code-input"
                    type="text"
                    name="invite_code"
                    placeholder="np. A3F2B7C1"
                    required
                    autocomplete="off"
                    class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 font-mono text-white uppercase placeholder-white/40 focus:ring-1 focus:ring-white/30 focus:outline-none"
                  />
                </div>
                <button
                  type="submit"
                  class="w-full rounded-lg bg-blue-600 px-4 py-2 font-semibold transition-colors hover:bg-blue-700"
                >
                  Dołącz
                </button>
              </form>
            </div>
          </div>
        ) : (
          <div class="space-y-4">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-xl">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                  <span class="text-sm text-blue-100/50">Budżet</span>
                  <h2 class="font-semibold">{budget.name ?? "Nasz budżet"}</h2>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-sm text-blue-100/50">Kod zaproszenia:</span>
                  <code id="invite-code" class="rounded bg-white/10 px-2 py-0.5 font-mono text-sm">
                    {budget.invite_code}
                  </code>
                  <button
                    id="copy-invite"
                    class="rounded border border-white/20 bg-white/10 px-2 py-0.5 text-xs transition-colors hover:bg-white/20"
                  >
                    Kopiuj
                  </button>
                </div>
              </div>
            </div>

            <ExpenseDashboard client:load budgetId={budget.id} currentUserId={user.id} />
          </div>
        )
      }
    </div>
  </div>
</Layout>

<script>
  const copyBtn = document.getElementById("copy-invite");
  const codeEl = document.getElementById("invite-code");
  if (copyBtn && codeEl) {
    copyBtn.addEventListener("click", () => {
      void navigator.clipboard.writeText(codeEl.textContent?.trim() ?? "").then(() => {
        copyBtn.textContent = "Skopiowano!";
        setTimeout(() => {
          copyBtn.textContent = "Kopiuj";
        }, 2000);
      });
    });
  }
</script>
