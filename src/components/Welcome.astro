---
import Topbar from "@/components/Topbar.astro";

const features = [
  {
    title: "Wspólny widok wydatków",
    body: "Oboje partnerzy widzą jedną listę wydatków bieżącego miesiąca — z informacją, kto dodał każdy wpis.",
    icon: "users",
  },
  {
    title: "Podsumowanie per kategoria",
    body: "Zobacz na jednym ekranie, ile poszło na jedzenie, transport czy mieszkanie — i gdzie wydatki rosną.",
    icon: "chart",
  },
  {
    title: "Synchronizacja w czasie rzeczywistym",
    body: "Wydatek dodany przez partnera pojawia się u Ciebie w kilka sekund — bez ręcznego odświeżania.",
    icon: "sync",
  },
];

const steps = [
  { n: "1", title: "Załóż konto", body: "Rejestracja zajmuje chwilę — wystarczy email i hasło." },
  { n: "2", title: "Połącz się z partnerem", body: "Wygeneruj kod zaproszenia albo wpisz kod od partnera." },
  { n: "3", title: "Dodawajcie wydatki", body: "Każdy wpis trafia do wspólnego budżetu i podsumowania." },
];
---

<div class="bg-cosmic relative min-h-screen w-full overflow-hidden text-slate-100">
  <!-- Subtle dotted texture, kept faint so the emerald backdrop glow leads. -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.35]"
    style="background-image: radial-gradient(circle, rgba(148,163,184,0.12) 1px, transparent 1px); background-size: 28px 28px;"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 px-4 py-6 sm:px-8">
    <Topbar />

    <!-- Hero -->
    <section class="mx-auto flex max-w-3xl flex-col items-center px-4 py-20 text-center sm:py-28">
      <span
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-xs font-medium text-emerald-300"
      >
        <span class="size-1.5 rounded-full bg-emerald-400"></span>
        Budżet domowy dla dwojga
      </span>
      <h1 class="mb-6 text-4xl leading-tight font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Wiedzcie, dokąd naprawdę<br class="hidden sm:block" /> idą wasze pieniądze
      </h1>
      <p class="mb-10 max-w-xl text-lg text-slate-400">
        Wspólny budżet dla pary — bez integracji bankowych i skomplikowanej konfiguracji. Dodawajcie wydatki, widzcie je
        razem i sprawdzajcie, które kategorie rosną.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href="/auth/signup"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-emerald-600 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-emerald-500"
        >
          Zacznij za darmo
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
            aria-hidden="true"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="/auth/signin"
          class="inline-flex items-center justify-center rounded-lg border border-slate-700 bg-slate-800/60 px-6 py-3 text-base font-medium text-slate-200 transition-colors hover:bg-slate-800"
        >
          Mam już konto
        </a>
      </div>
    </section>

    <!-- Features -->
    <section class="mx-auto grid max-w-5xl grid-cols-1 gap-5 px-4 pb-8 sm:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6 shadow-lg shadow-black/20">
            <span class="mb-4 flex size-10 items-center justify-center rounded-xl bg-emerald-500/15 text-emerald-400">
              {f.icon === "users" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="size-5"
                  aria-hidden="true"
                >
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
              )}
              {f.icon === "chart" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="size-5"
                  aria-hidden="true"
                >
                  <path d="M21.21 15.89A10 10 0 1 1 8 2.83" />
                  <path d="M22 12A10 10 0 0 0 12 2v10z" />
                </svg>
              )}
              {f.icon === "sync" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="size-5"
                  aria-hidden="true"
                >
                  <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
                  <path d="M21 3v5h-5" />
                  <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
                  <path d="M8 16H3v5" />
                </svg>
              )}
            </span>
            <h3 class="mb-2 text-base font-semibold text-white">{f.title}</h3>
            <p class="text-sm leading-relaxed text-slate-400">{f.body}</p>
          </div>
        ))
      }
    </section>

    <!-- How it works -->
    <section class="mx-auto max-w-5xl px-4 py-16">
      <h2 class="mb-10 text-center text-2xl font-semibold text-white">Jak to działa</h2>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
        {
          steps.map((s) => (
            <div class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
              <span class="mb-4 flex size-9 items-center justify-center rounded-full border border-emerald-500/30 bg-emerald-500/10 text-sm font-semibold text-emerald-300">
                {s.n}
              </span>
              <h3 class="mb-1.5 text-base font-semibold text-white">{s.title}</h3>
              <p class="text-sm leading-relaxed text-slate-400">{s.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Final CTA -->
    <section class="mx-auto max-w-3xl px-4 pt-4 pb-24">
      <div
        class="rounded-2xl border border-emerald-500/20 bg-gradient-to-b from-emerald-500/10 to-slate-900/40 p-8 text-center shadow-lg shadow-black/20 sm:p-10"
      >
        <h2 class="mb-3 text-2xl font-semibold text-white">Gotowi przejąć kontrolę nad budżetem?</h2>
        <p class="mx-auto mb-7 max-w-md text-sm text-slate-400">
          Załóżcie wspólny budżet w minutę i zobaczcie pierwszy wydatek już dziś.
        </p>
        <a
          href="/auth/signup"
          class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-emerald-500"
        >
          Załóż darmowe konto
        </a>
      </div>
    </section>

    <footer class="mx-auto max-w-5xl border-t border-slate-800 px-4 py-8 text-center text-xs text-slate-500">
      Home Budget · Wspólny budżet domowy
    </footer>
  </div>
</div>
