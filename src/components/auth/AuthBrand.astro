---
interface Props {
  subtitle?: string;
}

const { subtitle } = Astro.props;
---

<div class="mb-6 flex flex-col items-center text-center">
  <a href="/" class="group flex items-center gap-2.5" aria-label="Home Budget — strona główna">
    <span
      class="flex size-10 items-center justify-center rounded-xl bg-emerald-600 shadow-lg shadow-emerald-600/20 transition-colors group-hover:bg-emerald-500"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-5 text-white"
        aria-hidden="true"
      >
        <path
          d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"
        ></path>
        <path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"></path>
      </svg>
    </span>
    <span class="text-lg font-semibold text-white">Home Budget</span>
  </a>
  {subtitle && <p class="mt-3 text-sm text-slate-400">{subtitle}</p>}
</div>
