SUPABASE_URL=###
SUPABASE_KEY=###

# --- Integration tests only (copy into a gitignored .env.test, never commit) ---
# Values are printed by `npx supabase start`:
#   SUPABASE_URL                 -> "API URL"
#   SUPABASE_KEY                 -> "anon key"   (the app's anon key; assertion clients use this)
#   SUPABASE_SERVICE_ROLE_KEY    -> "service_role key"  (test teardown ONLY; bypasses RLS)
# SUPABASE_SERVICE_ROLE_KEY is read only by the test harness via process.env.
# It must NEVER be added to the astro:env schema or used by application code.
# SUPABASE_SERVICE_ROLE_KEY=###
